{
  "name": "@graphos-io/dashboard",
  "version": "1.0.0",
  "description": "GraphOS local dashboard — live LangGraph visualization and trace explorer",
  "license": "MIT",
  "author": "Ahmed Butt",
  "homepage": "https://github.com/ahmedbutt2015/graphos#readme",
  "bugs": "https://github.com/ahmedbutt2015/graphos/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedbutt2015/graphos.git",
    "directory": "packages/dashboard"
  },
  "keywords": [
    "langgraph",
    "dashboard",
    "observability",
    "graphos",
    "ai"
  ],
  "bin": {
    "graphos": "./bin/graphos.mjs"
  },
  "files": [
    "bin",
    "lib",
    "src",
    "public",
    ".next",
    "next.config.mjs",
    "next-env.d.ts",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "tsconfig.json",
    "ws-server.mjs",
    "server.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node server.mjs",
    "dev:next": "next dev -p 4000",
    "dev:ws": "node ws-server.mjs",
    "build": "next build",
    "start": "node bin/graphos.mjs dashboard",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && rm -rf .next/cache"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@graphos-io/core": "workspace:*",
    "@xyflow/react": "^12.3.5",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
