{
  "name": "@graphos-io/sdk",
  "version": "1.0.0",
  "description": "GraphOS SDK — wrap your LangGraph app with policy enforcement and live telemetry",
  "license": "MIT",
  "author": "Ahmed Butt",
  "homepage": "https://github.com/ahmedbutt2015/graphos#readme",
  "bugs": "https://github.com/ahmedbutt2015/graphos/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedbutt2015/graphos.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "langgraph",
    "agents",
    "observability",
    "policies",
    "loop-guard",
    "budget-guard",
    "telemetry",
    "graphos",
    "ai"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@graphos-io/core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
