{
  "name": "@graphos/sdk",
  "version": "0.0.0",
  "description": "GraphOS SDK — wrap your LangGraph app with policy enforcement and telemetry",
  "license": "MIT",
  "author": "Ahmed Butt",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@graphos/core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
